rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // REUSABLE HELPER FUNCTIONS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to fetch group membership (Master Gate)
    function isGroupMember(groupId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // ==========================================
    // EXISTING COLLECTIONS (USER SCOPED)
    // ==========================================

    // User Profiles
    match /profiles/{profileId} {
      allow read: if isSignedIn(); // Allow reading profiles to see names/pics in collaboration
      allow write: if isOwner(profileId);
    }

    // Tasks, Habits, Goals, Schedules, Remember Me
    match /tasks/{taskId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /rememberMe/{itemId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /habits/{habitId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /goals/{goalId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /schedules/{scheduleId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Bug/Problem Reports
    match /reports/{reportId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // Sent Encouragements Tracking
    match /sentEncouragements/{encouragementId} {
      allow read: if isSignedIn() && (resource == null || resource.data.senderId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // ==========================================
    // COMMITMENTS SHARE (PUBLIC/VIEWER + OWNER WRITE)
    // ==========================================
    match /commitments/{commitmentId} {
      // Anyone can read a shared commitment to view progress
      allow get: if true;
      allow list: if isSignedIn(); 

      // Allow anyone (both signed-in and guests) to create a shared commitment
      allow create: if request.resource.data.userId != null;
      
      allow update: if (
        // Case A: Owner updating their daily commitments
        (isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid) ||
        // Case B: Viewer reacting with emojis or posting encouraging comments (restricted update)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'comments']))
      );

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ==========================================
    // COLLABORATIVE COMMITMENT GROUPS
    // ==========================================
    match /groups/{groupId} {
      // Members can read group details
      allow get: if isSignedIn() && (request.auth.uid in resource.data.members);
      allow list: if isSignedIn(); // Allow listing groups they belong to (queries must filter by members)

      // Signed in user can create a group
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;

      // Members can update (to join, sync XP, or update metadata if admin)
      allow update: if isSignedIn() && (
        // If already a member, they can update
        (request.auth.uid in resource.data.members) ||
        // Or if joining using an invite code (their UID is appended to members)
        (request.auth.uid in request.resource.data.members)
      );

      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      // Nested collections inside groups
      
      // 1. Group Tasks
      match /tasks/{taskId} {
        allow read, write: if isGroupMember(groupId);
      }

      // 2. Group Activity Feed
      match /activities/{activityId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && request.resource.data.userId == request.auth.uid;
      }

      // 3. Discussion Thread Comments
      match /tasks/{taskId}/messages/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
